<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Weather</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', sans-serif;
    background: #f7f5f2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    color: #1a1a1a;
  }

  header { text-align: center; margin-bottom: 52px; }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    font-weight: 400;
    letter-spacing: -0.5px;
  }

  .date {
    font-size: 13px;
    font-weight: 300;
    color: #999;
    margin-top: 6px;
    letter-spacing: 0.04em;
  }

  /* Loading */
  #loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .spinner {
    width: 32px; height: 32px;
    border: 2px solid #e0ddd8;
    border-top-color: #1a1a1a;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .loading-label { font-size: 13px; color: #aaa; letter-spacing: 0.05em; }

  /* Error */
  #error { display: none; text-align: center; }
  .error-text { font-size: 14px; color: #c0392b; margin-bottom: 16px; }
  .retry {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    padding: 10px 24px;
    background: #1a1a1a;
    color: #f7f5f2;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: opacity 0.2s;
  }
  .retry:hover { opacity: 0.7; }

  /* Grid */
  #cards {
    display: grid;
    grid-template-columns: repeat(3, 300px);
    gap: 20px;
  }
  @media (max-width: 1000px) {
    #cards { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); width: 100%; max-width: 600px; }
  }

  /* Card */
  .card {
    background: #fff;
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    opacity: 0;
    transform: translateY(16px);
    animation: rise 0.5s ease forwards;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .card:hover {
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    transform: translateY(-3px);
  }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.2s; }
  @keyframes rise { to { opacity: 1; transform: translateY(0); } }

  .card-emoji { font-size: 40px; margin-bottom: 20px; display: block; }

  .city-name {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.3px;
    margin-bottom: 2px;
  }

  .country {
    font-size: 12px;
    font-weight: 300;
    color: #aaa;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .temp {
    font-size: 56px;
    font-weight: 300;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 8px;
  }
  .temp sup { font-size: 20px; font-weight: 400; letter-spacing: 0; vertical-align: super; }

  .condition { font-size: 13px; color: #888; letter-spacing: 0.03em; }

  .divider { height: 1px; background: #f0ede9; margin: 24px 0; }

  .meta { display: flex; justify-content: space-between; }
  .meta-item { display: flex; flex-direction: column; gap: 4px; }
  .meta-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: #bbb; font-weight: 500; }
  .meta-value { font-size: 15px; color: #444; }

  footer { margin-top: 48px; font-size: 11px; color: #ccc; letter-spacing: 0.05em; }
  footer a { color: #bbb; }
</style>
</head>
<body>

<header>
  <h1>Weather</h1>
  <p class="date" id="date-line"></p>
</header>

<div id="loading">
  <div class="spinner"></div>
  <p class="loading-label">Fetching conditions…</p>
</div>

<div id="error">
  <p class="error-text">Unable to fetch weather data. Please try again.</p>
  <button class="retry" onclick="loadWeather()">Try again</button>
</div>

<div id="cards"></div>

<footer>Data by <a href="https://open-meteo.com" target="_blank">Open-Meteo</a> · No API key required</footer>

<script>
  const CITIES = [
    { name: "Delhi",  country: "India", lat: 28.6139, lon: 77.2090  },
    { name: "London", country: "UK",    lat: 51.5074, lon: -0.1278  },
    { name: "Tokyo",  country: "Japan", lat: 35.6762, lon: 139.6503 },
  ];

  function decode(code) {
    const map = {
      0:["Clear Sky","☀️"],    1:["Mainly Clear","🌤️"], 2:["Partly Cloudy","⛅"],
      3:["Overcast","☁️"],     45:["Foggy","🌫️"],       48:["Icy Fog","🌫️"],
      51:["Light Drizzle","🌦️"],53:["Drizzle","🌦️"],   55:["Heavy Drizzle","🌧️"],
      61:["Light Rain","🌧️"],  63:["Rain","🌧️"],        65:["Heavy Rain","🌧️"],
      71:["Light Snow","🌨️"],  73:["Snow","❄️"],         75:["Heavy Snow","❄️"],
      80:["Showers","🌦️"],     81:["Showers","🌧️"],     82:["Storms","⛈️"],
      95:["Thunderstorm","⛈️"],99:["Thunderstorm","🌩️"],
    };
    const [label, emoji] = map[code] ?? ["Unknown","🌡️"];
    return { label, emoji };
  }

  async function fetchCity(city) {
    const url = `https://api.open-meteo.com/v1/forecast?latitude=${city.lat}&longitude=${city.lon}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weathercode&timezone=auto`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    return { city, cur: data.current };
  }

  function buildCard({ city, cur }) {
    const { label, emoji } = decode(cur.weathercode);
    const card = document.createElement("div");
    card.className = "card";
    card.innerHTML = `
      <span class="card-emoji">${emoji}</span>
      <div class="city-name">${city.name}</div>
      <div class="country">${city.country}</div>
      <div class="temp">${Math.round(cur.temperature_2m)}<sup>°C</sup></div>
      <div class="condition">${label}</div>
      <div class="divider"></div>
      <div class="meta">
        <div class="meta-item">
          <span class="meta-label">Humidity</span>
          <span class="meta-value">${cur.relative_humidity_2m}%</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Wind</span>
          <span class="meta-value">${Math.round(cur.wind_speed_10m)} km/h</span>
        </div>
      </div>
    `;
    return card;
  }

  async function loadWeather() {
    const loadEl  = document.getElementById("loading");
    const errorEl = document.getElementById("error");
    const cardsEl = document.getElementById("cards");

    loadEl.style.display  = "flex";
    errorEl.style.display = "none";
    cardsEl.innerHTML     = "";

    try {
      // Fetch all 3 cities simultaneously
      const results = await Promise.all(CITIES.map(fetchCity));
      loadEl.style.display = "none";
      results.forEach(r => cardsEl.appendChild(buildCard(r)));
    } catch (e) {
      loadEl.style.display  = "none";
      errorEl.style.display = "block";
    }
  }

  document.getElementById("date-line").textContent =
    new Date().toLocaleDateString("en-GB", { weekday:"long", day:"numeric", month:"long", year:"numeric" });

  loadWeather();
</script>
</body>
</html>
